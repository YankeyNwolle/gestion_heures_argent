# Configuration GestHeures - Docker
# Copiez ce fichier vers .env pour personnaliser votre installation

# Base de données
DB_USER=gestheures
DB_PASSWORD=gestheures
DB_NAME=gestheures

# Sécurité
JWT_SECRET=remplacez_ce_secret_par_une_chaine_longue_et_aleatoire_en_production

# Ports (facultatif si vous gardez les défauts)
# BACKEND_PORT=5000
# FRONTEND_PORT=8080
